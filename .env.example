# DoorDash Somalia MVP - Secure .env Template 🛡️\n\n# Database (use PostgreSQL for prod)\nDB_URL=postgresql://user:pass@localhost:5432/doordash_somalia\n\n# Auth/JWT\nJWT_SECRET=your-64-char-jwt-secret-here-rotate-90d\n\n# Rate Limit (Redis-backed)\nREDIS_URL=redis://localhost:6379\nRATE_LIMIT_WINDOW_MS=60000  # 1min\nRATE_LIMIT_MAX=100  # per IP\n\n# COD Fraud Guards\nCOD_MIN_ORDER_VALUE=5000  # SYP\nCOD_MAX_ORDERS_PER_HOUR=5\nCOD_SUSPICIOUS_PATTERNS=high_freq_small_orders\n\n# Logging/Monitoring\nLOG_LEVEL=info\nSENTRY_DSN=\n\n# API Keys (rotate regularly)\nMAPS_API_KEY=\nPAYMENT_GATEWAY_KEY=\n\n# Somalia Location Model\nLOCATION_RADIUS_KM=5  # landmark verification\nPHONE_PREFIX=252  # Somali mobile\n\n# NEVER commit real values. Use .env.local for dev, secrets manager (Doppler/SSM) for prod.